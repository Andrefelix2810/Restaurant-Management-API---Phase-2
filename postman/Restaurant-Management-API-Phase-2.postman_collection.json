{
  "info": {
    "name": "Restaurant Management API - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userTypeId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "restaurantId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "User Types",
      "item": [
        {
          "name": "Create User Type - Restaurant Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('userTypeId', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DONO_RESTAURANTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "Create User Type - Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "List User Types",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "Get User Type By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/user-types/{{userTypeId}}"
          }
        },
        {
          "name": "Update User Type",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DONO_RESTAURANTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types/{{userTypeId}}"
          }
        },
        {
          "name": "Delete User Type",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/user-types/{{userTypeId}}"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Restaurant Owner User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('userId', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joao Silva\",\n  \"email\": \"joao{{$timestamp}}@email.com\",\n  \"login\": \"joao{{$timestamp}}\",\n  \"password\": \"123456\",\n  \"userTypeId\": {{userTypeId}},\n  \"address\": {\n    \"street\": \"Rua Central\",\n    \"number\": \"100\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01001000\",\n    \"complement\": \"Sala 12\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Update User Type Association",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joao Silva\",\n  \"email\": \"joao{{$timestamp}}@email.com\",\n  \"login\": \"joao{{$timestamp}}\",\n  \"password\": \"123456\",\n  \"userTypeId\": {{userTypeId}},\n  \"address\": {\n    \"street\": \"Rua Central\",\n    \"number\": \"100\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01001000\",\n    \"complement\": \"Sala 12\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "Create Restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('restaurantId', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Restaurante Sabor Brasil\",\n  \"address\": \"Rua das Flores, 123 - Sao Paulo/SP\",\n  \"cuisineType\": \"Brasileira\",\n  \"openingHours\": \"Segunda a sabado, das 11h as 23h\",\n  \"ownerId\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/restaurants"
          }
        },
        {
          "name": "Get All Restaurants",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants"
          }
        },
        {
          "name": "Get Restaurant By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}"
          }
        },
        {
          "name": "Update Restaurant",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Restaurante Sabor Brasil Unidade Centro\",\n  \"address\": \"Rua das Flores, 456 - Sao Paulo/SP\",\n  \"cuisineType\": \"Brasileira\",\n  \"openingHours\": \"Todos os dias, das 11h as 23h\",\n  \"ownerId\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}"
          }
        },
        {
          "name": "Delete Restaurant",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}"
          }
        }
      ]
    }
  ]
}
