            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joao Silva\",\n  \"email\": \"joao{{$timestamp}}@email.com\",\n  \"login\": \"joao{{$timestamp}}\",\n  \"password\": \"123456\",\n  \"userTypeId\": {{userTypeId}},\n  \"address\": {\n    \"street\": \"Rua Central\",\n    \"number\": \"100\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01001000\",\n    \"complement\": \"Sala 12\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
