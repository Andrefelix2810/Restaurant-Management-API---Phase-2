{
  "info": {
    "name": "Restaurant Management API - Phase 2",
    "description": "Fluxo completo da Fase 2. A base inicia com CLIENTE no id 1, DONO_RESTAURANTE no id 2 e um usuario de cada tipo. Os ids dos tipos sao reutilizados por qualquer quantidade de usuarios. A collection localiza e reutiliza o catalogo inicial.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let reusableUserType = false;",
          "try {",
          "  reusableUserType = pm.request.method === 'POST' && pm.request.url.toString().endsWith('/user-types') && pm.response.code === 400 && pm.response.json().message.includes('already registered');",
          "} catch (error) {}",
          "pm.test('Status code is successful or an existing user type will be reused', function () {",
          "  pm.expect([200, 201, 204].includes(pm.response.code) || reusableUserType).to.be.true;",
          "});",
          "if (pm.response.code !== 204) {",
          "  pm.test('Response is JSON', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userTypeId",
      "value": "2"
    },
    {
      "key": "customerUserTypeId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "2"
    },
    {
      "key": "customerUserId",
      "value": "1"
    },
    {
      "key": "restaurantId",
      "value": "1"
    },
    {
      "key": "menuItemId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "User Types",
      "item": [
        {
          "name": "Create User Type - Restaurant Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('userTypeId', response.id);",
                  "} else if (pm.response.code === 400) {",
                  "  pm.sendRequest(pm.collectionVariables.get('baseUrl') + '/user-types', function (error, response) {",
                  "    pm.expect(error).to.equal(null);",
                  "    const userType = response.json().find(item => item.name === 'DONO_RESTAURANTE');",
                  "    pm.expect(userType, 'DONO_RESTAURANTE must exist').to.exist;",
                  "    pm.collectionVariables.set('userTypeId', userType.id);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DONO_RESTAURANTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "Create User Type - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('customerUserTypeId', response.id);",
                  "} else if (pm.response.code === 400) {",
                  "  pm.sendRequest(pm.collectionVariables.get('baseUrl') + '/user-types', function (error, response) {",
                  "    pm.expect(error).to.equal(null);",
                  "    const userType = response.json().find(item => item.name === 'CLIENTE');",
                  "    pm.expect(userType, 'CLIENTE must exist').to.exist;",
                  "    pm.collectionVariables.set('customerUserTypeId', userType.id);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "List User Types",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/user-types"
          }
        },
        {
          "name": "Get User Type By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/user-types/{{userTypeId}}"
          }
        },
        {
          "name": "Update User Type",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DONO_RESTAURANTE\"\n}"
            },
            "url": "{{baseUrl}}/user-types/{{userTypeId}}"
          }
        }
      ]
    },
