{
  "info": {
    "name": "Restaurant Management API - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userTypeId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Create User Type",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CUSTOMER\",\n  \"description\": \"Restaurant customer\"\n}"
        },
        "url": "{{baseUrl}}/user-types"
      }
    },
    {
      "name": "List User Types",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/user-types"
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Maria Silva\",\n  \"email\": \"maria@email.com\",\n  \"login\": \"mariasilva\",\n  \"password\": \"123456\",\n  \"userTypeId\": {{userTypeId}},\n  \"address\": {\n    \"street\": \"Rua Central\",\n    \"number\": \"100\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01001000\",\n    \"complement\": \"Apto 12\"\n  }\n}"
        },
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users"
      }
    }
  ]
}
